# Neo Group Upload Server — Environment Variables
# Copy this to .env and fill in all values before starting

# Google OAuth2 credentials (from Google Cloud Console)
CLIENT_ID=your_google_oauth_client_id_here
CLIENT_SECRET=your_google_oauth_client_secret_here

# Must match exactly what you set in Google Cloud Console → Authorized redirect URIs
REDIRECT_URI=https://form.neogrouplimited.com/oauth/callback

# Google Drive folder ID for "Neogroup Inquiry Files"
# Get from Drive URL: /drive/folders/THIS_ID
DRIVE_FOLDER_ID=your_drive_folder_id_here

# Port the server listens on (nginx proxies to this)
PORT=4000

# Only this origin can call /upload
ALLOWED_ORIGIN=https://form.neogrouplimited.com

# Path to store the OAuth token (keep outside web root)
TOKEN_PATH=/var/www/neogroup-upload/token.json
